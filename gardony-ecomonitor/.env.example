# Environment Variables for cPanel Deployment
# Copy this to .env file in uhi-api root directory

# ================================================================================
# EARTH ENGINE AUTHENTICATION
# ================================================================================

# Option 1: Service Account (Recommended for Production)
# Step 1: Create service account in Google Cloud Console
# Step 2: Download JSON key file
# Step 3: Upload to cPanel (e.g., /home/username/uhi-api/ee-service-account.json)
# Step 4: Set these variables:

EE_SERVICE_ACCOUNT=your-service-account-email@your-project.iam.gserviceaccount.com
EE_PRIVATE_KEY=/home/yourusername/uhi-api/ee-service-account.json

# Option 2: Default Credentials (Development Only)
# Leave both EE_* variables blank, the app will use default authentication
# Requires: earthengine authenticate (run locally first)

# ================================================================================
# APPLICATION SETTINGS (Optional - defaults work fine)
# ================================================================================

LOG_LEVEL=INFO
DEBUG=false

# ================================================================================
# CORS ORIGINS (Update for production)
# ================================================================================
# For cPanel: Add your domain via passenger_wsgi.py or main.py
# Local dev: http://localhost:5173,http://127.0.0.1:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
